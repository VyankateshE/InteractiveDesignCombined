server:
  port: 8081

  tomcat:
    threads:
      max: 200

    max-swallow-size: -1

    max-http-form-post-size: -1

    max-part-count: 20000

    connection-timeout: 600000

spring:
  servlet:
    multipart:
      enabled: true

      max-file-size: 10GB

      max-request-size: 10GB

      file-size-threshold: 10MB

      resolve-lazily: true

      location: temp/