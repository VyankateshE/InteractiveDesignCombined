	private static class PdfZipTaskResult {
	    private final String sourceName;
	    private final String fileType;
	    private final byte[] pdfBytes;
	    private final String errorMessage;

	    private PdfZipTaskResult(String sourceName, String fileType, byte[] pdfBytes, String errorMessage) {
	        this.sourceName = sourceName;
	        this.fileType = fileType;
	        this.pdfBytes = pdfBytes;
	        this.errorMessage = errorMessage;
	    }

	    private static PdfZipTaskResult success(String sourceName, String fileType, byte[] pdfBytes) {
	        return new PdfZipTaskResult(sourceName, fileType, pdfBytes, null);
	    }

	    private static PdfZipTaskResult failure(String sourceName, String errorMessage) {
	        return new PdfZipTaskResult(sourceName, null, null, errorMessage);
	    }

	    private boolean isSuccess() {
	        return pdfBytes != null && pdfBytes.length > 0;
	    }
	}

	public void processZipAndGeneratePdf(
	        String payloadJson,
	        MultipartFile zipFile,
	        MultipartFile htmlFile,
	        OutputStream responseStream) throws Exception {

	    ObjectMapper mapper = new ObjectMapper();
	    JsonNode payloadNode = mapper.readTree(payloadJson);
	    JsonNode mappingNode;
	    String pageSize = "A4";
	    String orientation = "portrait";

	    if (payloadNode.isArray()) {
	        mappingNode = payloadNode;
	    } else if (payloadNode.has("mapping")) {
	        mappingNode = payloadNode.get("mapping");
	        if (payloadNode.has("pageSize")) {
	            pageSize = payloadNode.get("pageSize").asText();
	        }
	        if (payloadNode.has("orientation")) {
	            orientation = payloadNode.get("orientation").asText();
	        }
	    } else {
	        throw new IllegalArgumentException("Invalid payload format.");
	    }

	    Map<String, JsonNode> htmlIdToJsonField = new LinkedHashMap<>();
	    for (JsonNode obj : mappingNode) {
	        obj.fields().forEachRemaining(entry ->
	                htmlIdToJsonField.put(entry.getKey(), entry.getValue()));
	    }

	    List<String> fileNameFields = extractTextList(htmlIdToJsonField.get("file_name"));
	    List<String> passwordFields = extractTextList(htmlIdToJsonField.get("password"));
	    String htmlContent = new String(htmlFile.getBytes(), StandardCharsets.UTF_8)
	            .replaceFirst("^\uFEFF", "");

	    RestTemplate restTemplate = new RestTemplate();
	    Set<String> usedNames = new HashSet<>();
	    StringBuilder generationErrors = new StringBuilder();
	    ExecutorService executor = Executors.newFixedThreadPool(5);
	    CompletionService<PdfZipTaskResult> completionService =
	            new ExecutorCompletionService<>(executor);

	    final int maxInFlight = 5;
	    int submitted = 0;
	    int completed = 0;
	    int generatedCount = 0;

	    try (ZipInputStream zis = new ZipInputStream(zipFile.getInputStream());
	         ZipOutputStream zos = new ZipOutputStream(responseStream)) {

	        ZipEntry jsonEntry;
	        while ((jsonEntry = zis.getNextEntry()) != null) {
	            try {
	                if (jsonEntry.isDirectory()
	                        || !jsonEntry.getName().toLowerCase().endsWith(".json")) {
	                    continue;
	                }

	                byte[] jsonBytes = readCurrentZipEntry(zis);
	                if (jsonBytes.length == 0) {
	                    continue;
	                }

	                completionService.submit(createPdfZipTask(
	                        jsonEntry.getName(),
	                        jsonBytes,
	                        mapper,
	                        restTemplate,
	                        htmlContent,
	                        htmlIdToJsonField,
	                        fileNameFields,
	                        passwordFields,
	                        pageSize,
	                        orientation));
	                submitted++;

	                if (submitted - completed >= maxInFlight) {
	                    PdfZipTaskResult result = takePdfResult(completionService);
	                    completed++;
	                    if (writePdfZipResult(result, zos, usedNames, generationErrors)) {
	                        generatedCount++;
	                    }
	                }
	            } finally {
	                zis.closeEntry();
	            }
	        }

	        while (completed < submitted) {
	            PdfZipTaskResult result = takePdfResult(completionService);
	            completed++;
	            if (writePdfZipResult(result, zos, usedNames, generationErrors)) {
	                generatedCount++;
	            }
	        }

	        if (generatedCount == 0) {
	            if (generationErrors.length() == 0) {
	                generationErrors.append(
	                        "No PDF generated. Check multipart keys: use file, payload, and jsonZip/jsonFile."
	                );
	            }

	            zos.putNextEntry(new ZipEntry("_generation_errors.txt"));
	            zos.write(generationErrors.toString().getBytes(StandardCharsets.UTF_8));
	            zos.closeEntry();
	        }

	        zos.finish();
	        zos.flush();
	    } finally {
	        executor.shutdownNow();
	    }
	}

	private byte[] readCurrentZipEntry(ZipInputStream zis) throws IOException {
	    ByteArrayOutputStream jsonBaos = new ByteArrayOutputStream();
	    byte[] buffer = new byte[8192];
	    int len;
	    while ((len = zis.read(buffer)) != -1) {
	        jsonBaos.write(buffer, 0, len);
	    }
	    return jsonBaos.toByteArray();
	}

	private Callable<PdfZipTaskResult> createPdfZipTask(
	        String sourceName,
	        byte[] jsonBytes,
	        ObjectMapper mapper,
	        RestTemplate restTemplate,
	        String htmlContent,
	        Map<String, JsonNode> htmlIdToJsonField,
	        List<String> fileNameFields,
	        List<String> passwordFields,
	        String pageSize,
	        String orientation) {

	    return () -> {
	        try {
	            JsonNode dataJson = mapper.readTree(jsonBytes);
	            Iterator<Map.Entry<String, JsonNode>> users = dataJson.fields();
	            if (!users.hasNext()) {
	                return PdfZipTaskResult.failure(sourceName, "JSON file has no root user object");
	            }

	            Map.Entry<String, JsonNode> entry = users.next();
	            String userKey = entry.getKey();
	            JsonNode userNode = entry.getValue();
	            Map<String, JsonNode> normalizedFieldMap = normalizeUserFields(userKey, userNode);

	            Document doc = Jsoup.parse(htmlContent);
	            fillTemplate(doc, htmlIdToJsonField, normalizedFieldMap, userKey);

	            String fileType = buildZipFileName(fileNameFields, normalizedFieldMap, userKey);
	            byte[] pdfBytes = renderPdf(
	                    restTemplate,
	                    mapper,
	                    doc.outerHtml(),
	                    dataJson,
	                    fileType,
	                    pageSize,
	                    orientation);
	            pdfBytes = protectPdfIfNeeded(pdfBytes, passwordFields, normalizedFieldMap, userKey);

	            return PdfZipTaskResult.success(sourceName, fileType, pdfBytes);
	        } catch (Exception ex) {
	            return PdfZipTaskResult.failure(sourceName, ex.getMessage());
	        }
	    };
	}

	private PdfZipTaskResult takePdfResult(CompletionService<PdfZipTaskResult> completionService)
	        throws IOException {

	    try {
	        Future<PdfZipTaskResult> future = completionService.take();
	        return future.get();
	    } catch (InterruptedException ex) {
	        Thread.currentThread().interrupt();
	        throw new IOException("PDF ZIP generation interrupted", ex);
	    } catch (Exception ex) {
	        throw new IOException("PDF ZIP generation failed: " + ex.getMessage(), ex);
	    }
	}

	private boolean writePdfZipResult(
	        PdfZipTaskResult result,
	        ZipOutputStream zos,
	        Set<String> usedNames,
	        StringBuilder generationErrors) throws IOException {

	    if (result == null || !result.isSuccess()) {
	        generationErrors
	                .append(result != null ? result.sourceName : "unknown")
	                .append(" -> ")
	                .append(result != null ? result.errorMessage : "Unknown PDF generation error")
	                .append(System.lineSeparator());
	        return false;
	    }

	    String pdfName = uniqueZipEntryName(
	            sanitizeFileName(result.fileType),
	            "pdf",
	            usedNames);
	    zos.putNextEntry(new ZipEntry(pdfName));
	    zos.write(result.pdfBytes);
	    zos.closeEntry();
	    zos.flush();
	    repository.save(RecordEntity.builder().fileName(pdfName).build());
	    return true;
	}

	private String buildZipFileName(
	        List<String> fileNameFields,
	        Map<String, JsonNode> normalizedFieldMap,
	        String userKey) {

	    if (!fileNameFields.isEmpty()) {
	        for (String fnExpr : fileNameFields) {
	            String fnValue = resolveTemplateValue(
	                    normalizedFieldMap,
	                    userKey,
	                    fnExpr.trim());
	            if (fnValue != null && !fnValue.isEmpty()) {
	                return fnValue.replaceAll("[\\\\/:*?\"<>|]", "_");
	            }
	        }
	    }

	    return UUID.randomUUID().toString();
	}
	
	
	
	

	private List<String> extractTextList(JsonNode node) {
	    List<String> values = new ArrayList<>();
	    if (node == null)
	        return values;

	    if (node.isTextual()) {
	        for (String value : node.asText().split(",")) {
	            if (!value.trim().isEmpty())
	                values.add(value.trim());
	        }
	    } else if (node.isArray()) {
	        node.forEach(n -> {
	            if (!n.asText().trim().isEmpty())
	                values.add(n.asText().trim());
	        });
	    }
	    return values;
	}

	private Map<String, JsonNode> normalizeUserFields(String userKey, JsonNode userNode) {
	    Map<String, JsonNode> normalizedFieldMap = new HashMap<>();
	    normalizedFieldMap.put(userKey.toLowerCase(), userNode);
	    userNode.fieldNames().forEachRemaining(field ->
	            normalizedFieldMap.put(field.toLowerCase(), userNode.get(field)));
	    return normalizedFieldMap;
	}

	private void fillTemplate(
	        Document doc,
	        Map<String, JsonNode> htmlIdToJsonField,
	        Map<String, JsonNode> normalizedFieldMap,
	        String userKey) {

	    htmlIdToJsonField.forEach((id, nodeRef) -> {
	        String fieldRef = nodeRef.isTextual() ? nodeRef.asText() : null;
	        if (fieldRef == null)
	            return;

	        Element elem = doc.getElementById(id);
	        if (elem == null)
	            return;

	        String value = resolveTemplateValue(normalizedFieldMap, userKey, fieldRef);
	        if (value != null && !value.isEmpty())
	            elem.text(value);
	    });
	}

	private String resolveTemplateValue(
	        Map<String, JsonNode> normalizedFieldMap,
	        String userKey,
	        String fieldRef) {

	    String fullPath = fieldRef.startsWith(userKey + ".")
	            ? fieldRef
	            : userKey + "." + fieldRef;
	    String value = resolveFieldValueWithIndexes(normalizedFieldMap, fullPath.trim());

	    if (value != null && !value.isEmpty())
	        return value;

	    String aliasPath = resolveKnownTemplateAlias(fieldRef);
	    if (aliasPath == null)
	        return value;

	    String aliasFullPath = aliasPath.startsWith(userKey + ".")
	            ? aliasPath
	            : userKey + "." + aliasPath;
	    return resolveFieldValueWithIndexes(normalizedFieldMap, aliasFullPath.trim());
	}

	private String resolveKnownTemplateAlias(String fieldRef) {
	    if (fieldRef == null || fieldRef.startsWith("__i_designer_template_values."))
	        return null;

	    switch (fieldRef) {
	        case "customer_name":
	            return "customer_details.customer_name";
