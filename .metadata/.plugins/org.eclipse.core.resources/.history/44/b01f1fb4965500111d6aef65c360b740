server:
  port: 8081
  address: 192.168.0.188

  tomcat:
    threads:
      max: 200

    max-swallow-size: -1
    max-http-form-post-size: -1
    max-part-count: 20000
    connection-timeout: 600000

  compression:
    enabled: true
    min-response-size: 1024

    mime-types:
      - application/json
      - application/pdf
      - text/html
      - text/plain
      - application/octet-stream

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/videophase2
    username: root
    password: root
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    database-platform: org.hibernate.dialect.MySQL8Dialect

    hibernate:
      ddl-auto: update

    show-sql: false

    properties:
      hibernate:
        jdbc:
          batch_size: 100

        order_inserts: true
        order_updates: true

  servlet:
    multipart:
      enabled: true
      max-file-size: 10GB
      max-request-size: 10GB
      file-size-threshold: 10MB
      location: temp/

logging:
  level:
    root: INFO